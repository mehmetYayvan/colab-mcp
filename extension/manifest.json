{
  "manifest_version": 3,
  "name": "colab-mcp bridge",
  "version": "1.0",
  "description": "Lets Claude run and read Colab cells via local MCP server",
  "permissions": ["tabs", "scripting"],
  "host_permissions": [
    "https://colab.research.google.com/*",
    "http://localhost:7823/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://colab.research.google.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
